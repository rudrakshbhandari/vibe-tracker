{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022", "webworker"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@cloudflare/workers-types", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"]
}
