generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProfileVisibility {
  PRIVATE
  PUBLIC
}

enum LeaderboardVisibility {
  HIDDEN
  PUBLIC
}

enum FriendConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum FriendInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum LeaderboardWindow {
  DAYS_7
  DAYS_30
  DAYS_90
}

enum LeaderboardScope {
  GLOBAL
}

model GitHubAccount {
  id                       String                @id @default(cuid())
  githubUserId             Int                   @unique
  login                    String                @unique
  displayName              String?
  avatarUrl                String?
  bio                      String?
  profileVisibility        ProfileVisibility     @default(PRIVATE)
  leaderboardVisibility    LeaderboardVisibility @default(HIDDEN)
  socialOnboardingCompletedAt DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  authoredCommits          Commit[]              @relation("CommitAuthor")
  installationGrants       InstallationGrant[]
  sessions                 UserSession[]
  leaderboardSnapshots     LeaderboardSnapshot[]
  sentFriendConnections    FriendConnection[]    @relation("FriendConnectionRequester")
  receivedFriendConnections FriendConnection[]   @relation("FriendConnectionAddressee")
  sentFriendInvites        FriendInvite[]        @relation("FriendInviteInviter")
  claimedFriendInvites     FriendInvite[]        @relation("FriendInviteClaimer")
}

model Installation {
  id              String              @id @default(cuid())
  githubInstallId Int                 @unique
  accountType     String
  accountLogin    String
  targetType      String?
  permissionsJson String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  repositories    Repository[]
  syncJobs        SyncJob[]
  grants          InstallationGrant[]
}

model InstallationGrant {
  id             String        @id @default(cuid())
  accountId      String
  installationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  account        GitHubAccount @relation(fields: [accountId], references: [id])
  installation   Installation  @relation(fields: [installationId], references: [id])

  @@unique([accountId, installationId])
}

model UserSession {
  id                         String        @id @default(cuid())
  sessionToken               String        @unique
  accountId                  String
  githubAccessToken          String
  githubAccessTokenExpiresAt DateTime?
  githubRefreshToken         String?
  githubRefreshTokenExpiresAt DateTime?
  expiresAt                  DateTime
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  account                    GitHubAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Repository {
  id               String      @id @default(cuid())
  githubRepoId     Int         @unique
  owner            String
  name             String
  defaultBranch    String
  isPrivate        Boolean
  installationId   String
  installation     Installation @relation(fields: [installationId], references: [id])
  branches         Branch[]
  commits          Commit[]
  pullRequests     PullRequest[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Branch {
  id           String   @id @default(cuid())
  name         String
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  commitLinks   CommitBranch[]

  @@unique([repositoryId, name])
}

model Commit {
  id                    String         @id @default(cuid())
  sha                   String
  repositoryId          String
  repository            Repository     @relation(fields: [repositoryId], references: [id])
  authorId              String?
  author                GitHubAccount? @relation("CommitAuthor", fields: [authorId], references: [id])
  authorName            String?
  authorEmail           String?
  authoredAt            DateTime
  committedAt           DateTime
  messageHeadline       String
  additions             Int
  deletions             Int
  changedFiles          Int?
  mergedToDefaultBranch Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  branchLinks           CommitBranch[]
  pullRequestLinks      PullRequestCommit[]

  @@unique([repositoryId, sha])
}

model CommitBranch {
  id        String   @id @default(cuid())
  commitId  String
  branchId  String
  commit    Commit   @relation(fields: [commitId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])
  firstSeenAt DateTime @default(now())

  @@unique([commitId, branchId])
}

model PullRequest {
  id             String   @id @default(cuid())
  githubPrNumber Int
  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id])
  title          String
  state          String
  baseBranch     String
  headBranch     String
  openedAt       DateTime
  mergedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  commitLinks    PullRequestCommit[]

  @@unique([repositoryId, githubPrNumber])
}

model PullRequestCommit {
  id            String      @id @default(cuid())
  pullRequestId String
  commitId      String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id])
  commit        Commit      @relation(fields: [commitId], references: [id])

  @@unique([pullRequestId, commitId])
}

model SyncJob {
  id              String       @id @default(cuid())
  installationId  String
  installation    Installation @relation(fields: [installationId], references: [id])
  scope           String
  status          String
  startedAt       DateTime?
  finishedAt      DateTime?
  cursor          String?
  errorMessage    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model FriendConnection {
  id                 String                 @id @default(cuid())
  requesterAccountId String
  addresseeAccountId String
  pairKey            String                 @unique
  status             FriendConnectionStatus @default(PENDING)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  requester          GitHubAccount          @relation("FriendConnectionRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)
  addressee          GitHubAccount          @relation("FriendConnectionAddressee", fields: [addresseeAccountId], references: [id], onDelete: Cascade)

  @@index([requesterAccountId, status])
  @@index([addresseeAccountId, status])
}

model FriendInvite {
  id                 String             @id @default(cuid())
  token              String             @unique
  inviterAccountId   String
  claimedByAccountId String?
  status             FriendInviteStatus @default(PENDING)
  expiresAt          DateTime
  claimedAt          DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  inviter            GitHubAccount      @relation("FriendInviteInviter", fields: [inviterAccountId], references: [id], onDelete: Cascade)
  claimedBy          GitHubAccount?     @relation("FriendInviteClaimer", fields: [claimedByAccountId], references: [id], onDelete: SetNull)

  @@index([inviterAccountId, status])
}

model LeaderboardSnapshot {
  id             String           @id @default(cuid())
  accountId      String
  window         LeaderboardWindow
  scope          LeaderboardScope
  vibeScore      Int
  mergedAdditions Int
  mergedDeletions Int
  mergedCommits  Int
  activePeriods  Int
  rank           Int
  calculatedAt   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  account        GitHubAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, window, scope])
  @@index([window, scope, rank])
}
