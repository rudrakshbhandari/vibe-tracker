generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GitHubAccount {
  id                 String              @id @default(cuid())
  githubUserId       Int                 @unique
  login              String              @unique
  displayName        String?
  avatarUrl          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  installationGrants InstallationGrant[]
  pullRequests       PullRequest[]
  dailyStats         DailyUserRepoStats[]
  sessions           UserSession[]
}

model Installation {
  id              String              @id @default(cuid())
  githubInstallId Int                 @unique
  accountType     String
  accountLogin    String
  targetType      String?
  permissionsJson String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  repositories    Repository[]
  syncJobs        SyncJob[]
  syncCursors     SyncCursor[]
  grants          InstallationGrant[]
}

model InstallationGrant {
  id             String        @id @default(cuid())
  accountId      String
  installationId String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  account        GitHubAccount @relation(fields: [accountId], references: [id])
  installation   Installation  @relation(fields: [installationId], references: [id])

  @@unique([accountId, installationId])
}

model UserSession {
  id                         String        @id @default(cuid())
  sessionToken               String        @unique
  accountId                  String
  githubAccessToken          String
  githubAccessTokenExpiresAt DateTime?
  githubRefreshToken         String?
  githubRefreshTokenExpiresAt DateTime?
  expiresAt                  DateTime
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  account                    GitHubAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Repository {
  id             String            @id @default(cuid())
  githubRepoId   Int               @unique
  owner          String
  name           String
  defaultBranch  String
  isPrivate      Boolean
  installationId String
  installation   Installation      @relation(fields: [installationId], references: [id])
  pullRequests   PullRequest[]
  dailyStats     DailyUserRepoStats[]
  syncCursors    SyncCursor[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([installationId])
}

model PullRequest {
  id             String         @id @default(cuid())
  githubPrNumber Int
  repositoryId   String
  repository     Repository     @relation(fields: [repositoryId], references: [id])
  authorId       String?
  author         GitHubAccount? @relation(fields: [authorId], references: [id])
  title          String
  state          String
  baseBranch     String
  headBranch     String
  additions      Int            @default(0)
  deletions      Int            @default(0)
  changedFiles   Int?
  commitCount    Int            @default(0)
  openedAt       DateTime
  mergedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([repositoryId, githubPrNumber])
  @@index([repositoryId, mergedAt])
  @@index([authorId, mergedAt])
}

model DailyUserRepoStats {
  id            String        @id @default(cuid())
  accountId     String
  account       GitHubAccount @relation(fields: [accountId], references: [id])
  repositoryId  String
  repository    Repository    @relation(fields: [repositoryId], references: [id])
  day           DateTime
  additions     Int           @default(0)
  deletions     Int           @default(0)
  mergedPrCount Int           @default(0)
  commitCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([accountId, repositoryId, day])
  @@index([accountId, day])
  @@index([repositoryId, day])
}

model SyncCursor {
  id             String       @id @default(cuid())
  installationId String?
  repositoryId   String?
  installation   Installation? @relation(fields: [installationId], references: [id])
  repository     Repository?   @relation(fields: [repositoryId], references: [id])
  scope          String
  cursorValue    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([repositoryId, scope])
  @@index([installationId, scope])
}

model SyncJob {
  id             String       @id @default(cuid())
  installationId String
  installation   Installation @relation(fields: [installationId], references: [id])
  scope          String
  status         String
  startedAt      DateTime?
  finishedAt     DateTime?
  cursor         String?
  errorMessage   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([installationId, scope, status])
}
